#!/usr/bin/env python3
import argparse
import time

from pqnstack.pqn.drivers.rotator import ELL14KRotator


VALID_HEX = "0123456789ABCDEF"


def _norm_line(s: str) -> str:
    return s.strip().replace(" ", "")


def _read_matching_line(dev: ELL14KRotator, predicate, timeout_s: float) -> str | None:
    t0 = time.time()
    while time.time() - t0 < timeout_s:
        line = dev._readline_ascii()
        if not line:
            continue
        if predicate(line):
            return line
    return None


def read_gs(dev: ELL14KRotator, addr_hex: str, timeout_s: float) -> tuple[str | None, int | None]:
    addr_hex = addr_hex.upper()
    dev._drain_reads(0.05)
    dev._send(f"{addr_hex}gs")
    def pred(line: str) -> bool:
        n = _norm_line(line)
        return n.startswith(f"{addr_hex}GS") and len(n) >= 5
    line = _read_matching_line(dev, pred, timeout_s)
    if not line:
        return None, None
    n = _norm_line(line)
    code_hex = n[4:6] if len(n) >= 6 else None
    try:
        code = int(code_hex, 16) if code_hex is not None else None
    except Exception:
        code = None
    return line, code


def scan_devices(dev: ELL14KRotator) -> dict[str, dict[str, str]]:
    devices: dict[str, dict[str, str]] = {}
    dev._drain_reads(0.05)

    for a in VALID_HEX:
        dev._drain_reads(0.02)
        dev._send(f"{a}in")

        def pred(line: str) -> bool:
            n = _norm_line(line)
            return n.startswith(f"{a},IN,") or n.startswith(f"{a},IN") or n.startswith(f"{a}IN")

        reply = _read_matching_line(dev, pred, dev.timeout_s)
        if reply is None:
            continue

        try:
            parsed = dev._parse_in(reply)
        except Exception:
            parsed = {"raw": reply}
        devices[a] = parsed

    return devices


def print_devices(devices: dict[str, dict[str, str]]) -> None:
    if not devices:
        print("No Elliptec devices detected on this bus.")
        return

    print("Detected devices:")
    print("  Addr  SN         Year  FW   HW   TravelHex  PulsesHex")
    print("  ----  ---------  ----  ---  ---  ---------  ---------")
    for addr in sorted(devices.keys(), key=lambda x: int(x, 16)):
        info = devices[addr]
        sn = info.get("sn", "")
        year = info.get("year", "")
        fw = info.get("fw", "")
        hw = info.get("hw", "")
        travel = info.get("travel_hex", "")
        pulses = info.get("pulses_per_unit_hex", "")

        row = f"  {addr:>4}  {sn:>9}  {year:>4}  {fw:>3}  {hw:>3}  {travel:>9}  {pulses:>9}"
        if not sn and "raw" in info:
            row += f"   raw={info['raw']!r}"
        print(row)


def prompt_addr(prompt: str, valid_set: set[str] | None = None) -> str | None:
    while True:
        s = input(prompt).strip()
        if s.lower() == "q":
            return None
        if len(s) == 1 and s.upper() in VALID_HEX:
            s = s.upper()
            if valid_set is not None and s not in valid_set:
                print(f"Address {s} not in the set of detected devices: {sorted(valid_set)}")
                continue
            return s
        print("Invalid input. Enter a single hex digit [0-9, A-F] or 'q' to quit.")


def prompt_addr_list(prompt: str, valid_set: set[str] | None = None) -> list[str] | None:
    while True:
        s = input(prompt).strip()
        if s.lower() == "q":
            return None
        if not s:
            print("Enter one or more hex digits separated by commas/spaces, or 'q' to quit.")
            continue
        raw = s.replace(",", " ").split()
        addrs: list[str] = []
        ok = True
        for tok in raw:
            tok = tok.strip().upper()
            if len(tok) != 1 or tok not in VALID_HEX:
                ok = False
                break
            addrs.append(tok)
        if not ok or not addrs:
            print("Invalid input. Example: 1,2,A or 1 2 A. Or 'q' to quit.")
            continue
        uniq = []
        seen = set()
        for a in addrs:
            if a not in seen:
                uniq.append(a)
                seen.add(a)
        if valid_set is not None:
            bad = [a for a in uniq if a not in valid_set]
            if bad:
                print(f"These addresses are not detected on the bus: {bad}. Detected: {sorted(valid_set)}")
                continue
        return uniq


def prompt_sn(devices: dict[str, dict[str, str]]) -> tuple[str, dict[str, str]] | None:
    sn_map: dict[str, list[str]] = {}
    for addr, info in devices.items():
        sn = info.get("sn", "")
        if not sn:
            continue
        sn_map.setdefault(sn, []).append(addr)

    if not sn_map:
        print("No serial numbers available in IN replies for these devices.")
        return None

    sns_sorted = sorted(sn_map.keys())
    print("Serial numbers detected:")
    for idx, sn in enumerate(sns_sorted, start=1):
        addrs = ",".join(sorted(sn_map[sn], key=lambda x: int(x, 16)))
        print(f"  [{idx}] SN={sn} at addr(s) {addrs}")

    while True:
        s = input("Select device by index, or 'q' to cancel: ").strip()
        if s.lower() == "q":
            return None
        try:
            i = int(s)
        except ValueError:
            print("Invalid index.")
            continue
        if not (1 <= i <= len(sns_sorted)):
            print("Index out of range.")
            continue
        sn = sns_sorted[i - 1]
        addrs = sn_map[sn]
        if len(addrs) > 1:
            print(f"SN {sn} appears at multiple addresses: {addrs}")
            addr = prompt_addr(
                "Enter which address for this SN you want to select (or 'q' to cancel): ",
                valid_set=set(addrs),
            )
            if addr is None:
                return None
        else:
            addr = addrs[0]
        return addr, devices[addr]


def do_change_address(dev: ELL14KRotator, src: str, dst: str) -> None:
    src = src.upper()
    dst = dst.upper()
    before = scan_devices(dev)

    try:
        dev._drain_reads(0.05)
        dev._send(f"{src}ca{dst}")
        line, code = read_gs(dev, dst, timeout_s=max(dev.timeout_s, 0.5))
        if line:
            n = _norm_line(line)
            print(f"Reply: {n}")
        if code is not None and code != 0:
            print(f"Warning: status/error code {code} (0x{code:02X}) after ca")
    except Exception as exc:
        print(f"Error sending ca: {exc}")
        return

    time.sleep(0.1)
    after = scan_devices(dev)

    print()
    print("After change:")
    print_devices(after)

    moved = (src in before) and (dst in after) and (src not in after)
    if moved:
        print(f"Address change verified: device moved from {src} to {dst}.")
        return

    print("Warning: could not cleanly verify address change.")
    if src in after:
        print(f"  Device still responds at old address {src}.")
    if dst not in after:
        print(f"  No device responds at new address {dst}.")

    print("Attempting best-effort revert...")
    try:
        dev._drain_reads(0.05)
        dev._send(f"{dst}ca{src}")
        line2, _ = read_gs(dev, src, timeout_s=max(dev.timeout_s, 0.5))
        if line2:
            print(f"Revert reply: {_norm_line(line2)}")
        time.sleep(0.1)
        reverted = scan_devices(dev)
        print()
        print("After revert attempt:")
        print_devices(reverted)
    except Exception as exc:
        print(f"Revert attempt failed: {exc}")


def do_save_user_data(dev: ELL14KRotator, addr: str) -> None:
    addr = addr.upper()
    try:
        dev._drain_reads(0.05)
        dev._send(f"{addr}us")
        line, code = read_gs(dev, addr, timeout_s=max(dev.timeout_s, 0.5))
        if line:
            print(f"Reply: {_norm_line(line)}")
        else:
            print("No GS reply received to us; polling status...")
            line2, code2 = read_gs(dev, addr, timeout_s=max(dev.timeout_s, 0.5))
            if line2:
                print(f"Polled: {_norm_line(line2)}")
                code = code2
        if code is None:
            print("Warning: could not parse status/error code.")
        elif code != 0:
            print(f"Warning: status/error code {code} (0x{code:02X}) after us")
        else:
            print("Save user data accepted (GS00).")
    except Exception as exc:
        print(f"Error while sending us: {exc}")


def do_group_address(dev: ELL14KRotator, sources: list[str], group_addr: str) -> None:
    group_addr = group_addr.upper()
    for src in sources:
        src = src.upper()
        try:
            dev._drain_reads(0.05)
            dev._send(f"{src}ga{group_addr}")
            line, code = read_gs(dev, group_addr, timeout_s=max(dev.timeout_s, 0.5))
            if line:
                print(f"{src} -> {group_addr} reply: {_norm_line(line)}")
            else:
                print(f"{src} -> {group_addr}: no GS reply received")
            if code is not None and code != 0:
                print(f"{src} -> {group_addr}: warning status/error {code} (0x{code:02X})")
        except Exception as exc:
            print(f"{src} -> {group_addr}: error sending ga: {exc}")


def do_clear_group(dev: ELL14KRotator, sources: list[str]) -> None:
    for src in sources:
        src = src.upper()
        try:
            dev._drain_reads(0.05)
            dev._send(f"{src}ga{src}")
            line, code = read_gs(dev, src, timeout_s=max(dev.timeout_s, 0.5))
            if line:
                print(f"{src} cleared reply: {_norm_line(line)}")
            else:
                print(f"{src} cleared: no GS reply received")
            if code is not None and code != 0:
                print(f"{src} cleared: warning status/error {code} (0x{code:02X})")
        except Exception as exc:
            print(f"{src} cleared: error sending ga: {exc}")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Interactive Elliptec (ELLx) address tool for a single serial bus: scan (in), change address (ca), save (us), and group listen address (ga)."
    )
    parser.add_argument(
        "port",
        help="Serial device path, e.g. /dev/ttyUSB0 or COM3",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=0.3,
        help="Per-command read timeout in seconds used for scanning and replies (default: 0.3).",
    )
    args = parser.parse_args()

    dev = ELL14KRotator(
        name="addr_tool",
        desc="address configuration",
        hw_address=args.port,
        addr_hex="0",
    )
    dev.timeout_s = float(args.timeout)

    try:
        print(f"Opening {args.port}...")
        dev._open_port()
    except Exception as exc:
        print(f"Error opening port {args.port}: {exc}")
        return 1

    try:
        while True:
            print()
            devices = scan_devices(dev)
            print_devices(devices)

            if not devices:
                print("No devices found. Connect at least one device and press Enter to rescan, or 'q' to quit.")
                s = input("> ").strip()
                if s.lower() == "q":
                    return 0
                continue

            detected_addrs = set(devices.keys())

            print()
            print("Options:")
            print("  r - change a device base address (ca)")
            print("  n - select a device by serial number, then change base address (ca)")
            print("  u - save user data on a device (us)")
            print("  g - set group listen address for one or more devices (ga)")
            print("  x - clear group listen address for one or more devices (ga back to itself)")
            print("  s - rescan")
            print("  q - quit")
            choice = input("Enter choice [r/n/u/g/x/s/q]: ").strip().lower()

            if choice == "q":
                return 0
            if choice in ("s", ""):
                continue

            if choice == "r":
                print()
                print_devices(devices)
                src = prompt_addr(
                    "Enter address of device to change (single hex digit, or 'q' to cancel): ",
                    valid_set=detected_addrs,
                )
                if src is None:
                    continue
                dst = prompt_addr(
                    f"Enter NEW base address for device {src} [0-9, A-F], or 'q' to cancel: ",
                    valid_set=None,
                )
                if dst is None:
                    continue
                if dst == src:
                    print("New address equals current address. No change performed.")
                    continue
                if dst in detected_addrs:
                    print(f"Error: address {dst} is already in use by another detected device.")
                    continue
                print(f"Changing base address {src} -> {dst}...")
                do_change_address(dev, src, dst)
                continue

            if choice == "n":
                print()
                res = prompt_sn(devices)
                if res is None:
                    continue
                src, info = res
                print(f"Selected device at address {src} with SN={info.get('sn', '?')}")
                dst = prompt_addr(
                    f"Enter NEW base address for device {src} [0-9, A-F], or 'q' to cancel: ",
                    valid_set=None,
                )
                if dst is None:
                    continue
                if dst == src:
                    print("New address equals current address. No change performed.")
                    continue
                if dst in detected_addrs:
                    print(f"Error: address {dst} is already in use by another detected device.")
                    continue
                print(f"Changing base address {src} -> {dst}...")
                do_change_address(dev, src, dst)
                continue

            if choice == "u":
                addr = prompt_addr(
                    "Enter address of device to save (us) [0-9, A-F], or 'q' to cancel: ",
                    valid_set=detected_addrs,
                )
                if addr is None:
                    continue
                do_save_user_data(dev, addr)
                continue

            if choice == "g":
                srcs = prompt_addr_list(
                    "Enter one or more source addresses to group (e.g. 1,2,A), or 'q' to cancel: ",
                    valid_set=detected_addrs,
                )
                if srcs is None:
                    continue
                grp = prompt_addr(
                    "Enter group listen address [0-9, A-F], or 'q' to cancel: ",
                    valid_set=None,
                )
                if grp is None:
                    continue
                do_group_address(dev, srcs, grp)
                continue

            if choice == "x":
                srcs = prompt_addr_list(
                    "Enter one or more addresses to clear group listen mapping (e.g. 1,2,A), or 'q' to cancel: ",
                    valid_set=detected_addrs,
                )
                if srcs is None:
                    continue
                do_clear_group(dev, srcs)
                continue

            print("Unknown choice.")

    finally:
        try:
            dev.close()
        except Exception:
            pass

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
