#!/usr/bin/env python

import json
import sys
from collections.abc import Callable
from http.server import BaseHTTPRequestHandler, HTTPServer
import json

from pqnstack.pqn.drivers.polarimeter2 import ArduinoPolarimeter
from pqnstack.network.client import Client
from pqnstack.pqn.protocols.chsh import measure_chsh

HOST = "127.0.0.1"
PORT = 8000
ADDRESS = (HOST, PORT)


@dataclass
class MockPolarimeter:
    angle: float = 0.0


def get_handler(mp: MockPolarimeter) -> Callable[..., BaseHTTPRequestHandler]:
    class RequestHandler(BaseHTTPRequestHandler):
        angle: float = 0.0

        def do_OPTIONS(self) -> None:  # noqa: N802
            status = 200
            self.send_response(status)
            self.send_header("Access-Control-Allow-Origin", "https://pqnetwork.web.illinois.edu")
            self.send_header("Access-Control-Allow-Methods", "GET, POST, HEAD, OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type, Cache-Control, Authorization")
            self.send_header("Access-Control-Allow-Credentials", "true")
            self.send_header("Access-Control-Allow-Private-Network", "true")
            self.end_headers()

        def do_GET(self) -> None:  # noqa: N802
            status = 200
            content_type = "text/plain"
            response_content = ""
            parts = self.path.split("?")

            if parts[0] == "/polarimeter":
                global theta_value
                response_content = f"{theta_value:.2f}"
            else:
                status = 404

            self.send_response(status)
            self.send_header("Access-Control-Allow-Origin", "https://pqnetwork.web.illinois.edu")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Type", content_type)
            self.end_headers()
            self.wfile.write(bytes(response_content, "utf-8"))
            
        def do_POST(self) -> None:  # noqa: N802
            status = 200
            content_type = "text/plain"
            response_content = ""

            if self.path == "/polarimeter/start_normalizing":
                print("post set normalizing")
                polarimeter.reset()
                polarimeter.set_calibration(True)
            elif self.path == "/polarimeter/stop_normalizing":
                polarimeter.set_calibration(False)
            elif self.path == "/polarimeter/set_angle1":
                content_length = int(self.headers["Content-Length"])
                post_data = self.rfile.read(content_length).decode("utf-8")
                try:
                    data = json.loads(post_data)
                    print(f"data = {data}")
                    angle1 = float(data.get("degree", 0))
                    print(f"angle1 set to {angle1}")
                except (json.JSONDecodeError, ValueError) as e:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(bytes("Invalid JSON data", "utf-8"))
                    return
            elif self.path == "/polarimeter/set_angle2":
                content_length = int(self.headers["Content-Length"])
                post_data = self.rfile.read(content_length).decode("utf-8")
                try:
                    data = json.loads(post_data)
                    angle1 = float(data.get("degree", 0))
                    print(f"angle2 set to {angle2}")
                except (json.JSONDecodeError, ValueError) as e:
                    self.send_response(400)
                    self.end_headers()
                    self.wfile.write(bytes("Invalid JSON data", "utf-8"))
                    return

                c = Client(host = "172.30.63.109", timeout = 30000)
                idler_hwp = c.get_device("loomis_server", "idler_hwp")
                signal_hwp = c.get_device("loomis_server", "signal_hwp")
                timetagger = c.get_device("mini_pc", "tagger")
                print("starting chsh")
                result = measure_chsh([self.angle1/2, self.angle2/2], [(angle1/2)+22.5, (angle1/2)+67.5], idler_hwp, idler_hwp, signal_hwp, signal_hwp, timetagger, 15)
                print(result)
                response_content = json.dumps({"chsh_value": result})

            else:
                status = 404

            self.send_response(status)
            self.send_header("Access-Control-Allow-Origin", "https://pqnetwork.web.illinois.edu")
            self.send_header("Content-Type", content_type)
            self.end_headers()
            self.wfile.write(bytes(response_content, "utf-8"))

        def do_POST(self) -> None:  # noqa: N802
            status = 200
            content_type = "text/plain"
            response_content = ""

            if self.path == "/polarimeter":
                content_length = int(self.headers["Content-Length"])
                post_data = self.rfile.read(content_length)
                json_data = json.loads(post_data.decode())
                angle = json_data["angle"]

                response_content = f"Setting angle to {angle:.2f}"
                mp.angle = angle
            else:
                status = 404

            self.send_response(status)
            self.send_header("Access-Control-Allow-Origin", "https://pqnetwork.web.illinois.edu")
            self.send_header("Content-Type", content_type)
            self.end_headers()
            self.wfile.write(bytes(response_content, "utf-8"))

    return RequestHandler


if __name__ == "__main__":
    sys.stdout.write("Initializing server...\n")
    httpd = HTTPServer(ADDRESS, get_handler(MockPolarimeter()))

    input_thread = threading.Thread(target=update_theta, daemon=True)
    input_thread.start()

    httpd = HTTPServer(ADDRESS, get_handler())

    sys.stdout.write(f"Server started at http://{HOST}:{PORT}/\n")
    try:
        sys.stdout.write(f"Server started at http://{HOST}:{PORT}/\n")
        httpd.serve_forever()
    except KeyboardInterrupt:
        httpd.shutdown()
